# ============================================================================
# Configuração Nexus - Ingestão de Dados
# ============================================================================
# Copie este arquivo para .env e preencha com suas credenciais

# Supabase Configuration
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-chave-publica-anon
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role

# Banco de Dados
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexus
DB_USER=postgres
DB_PASSWORD=

# FlutterFlow (Configuração Futura)
FLUTTER_FLOW_URL=
FLUTTER_FLOW_API_KEY=

# Configuração de Logging
LOG_LEVEL=INFO
LOG_FILE=import_getnet.log

# Diretórios
CSV_INPUT_DIR=./data/input
JSON_OUTPUT_DIR=./data/output
